{
  "name": "@mermaid2aichat/vscode-extension",
  "version": "1.0.0",
  "private": true,
  "description": "Mermaid2AIChat VSCode 插件 — 可视化编辑流程图，通过 MCP 与 AI 对话集成",
  "type": "commonjs",
  "main": "./dist/extension.js",
  "engines": {
    "vscode": "^1.85.0"
  },
  "activationEvents": [],
  "contributes": {
    "commands": [
      {
        "command": "mermaid2aichat.openPanel",
        "title": "打开 Mermaid2AIChat",
        "category": "Mermaid2AIChat"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "mermaid2aichat",
          "title": "Mermaid2AIChat",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "mermaid2aichat": [
        {
          "id": "mermaid2aichat.welcome",
          "name": "Mermaid2AIChat",
          "when": "!mermaid2aichat.panelOpen"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "mermaid2aichat.openPanel",
          "when": "view == mermaid2aichat.welcome",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "build:webview": "vite build --config webview/vite.config.ts",
    "build:extension": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --target=node18",
    "build": "pnpm build:webview && pnpm build:extension",
    "dev:webview": "vite build --config webview/vite.config.ts --watch",
    "dev:extension": "pnpm build:extension --watch",
    "typecheck": "tsc --noEmit",
    "package": "pnpm build && vsce package --no-dependencies"
  },
  "dependencies": {
    "@mermaid2aichat/serializer": "workspace:*",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@mermaid2aichat/editor": "workspace:*",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/vscode": "^1.85.0",
    "@types/ws": "^8.5.10",
    "@vitejs/plugin-react": "^4.3.0",
    "esbuild": "^0.21.5",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  }
}
