{
  "name": "@mermaid2aichat/serializer",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "browser": {
        "types": "./dist/browser.d.ts",
        "import": "./dist/browser.js",
        "require": "./dist/browser.cjs"
      },
      "import": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "require": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "compile:jison": "tsx scripts/compile-jison.mts",
    "build": "pnpm compile:jison && tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "dagre": "^0.8.5",
    "dayjs": "^1.11.21",
    "jison": "^0.4.18",
    "js-yaml": "^5.0.0"
  },
  "devDependencies": {
    "@types/dagre": "^0.7.54",
    "@types/js-yaml": "^4.0.9",
    "tsup": "^8.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
